# ── Kehitys (kopioi → .env.local) ────────────────────────────────────────────
#
# Next.js lukee .env.local automaattisesti kehityksessä (ei tuotannossa).
# Älä commitoi .env.local versionhallintaan.

# Backendin osoite. Kehityksessä backend pyörii eri portissa.
NEXT_PUBLIC_API_URL=http://localhost:8000

# basePath ja assetPrefix next.config.ts:ssa.
# Sama polku kuin tuotannossa → kehitys vastaa tuotantoa täysin.
NEXT_PUBLIC_BASE_PATH=/inboxpilot

# ── Tuotanto (kopioi → .env.production.local palvelimella) ───────────────────
#
# NEXT_PUBLIC_API_URL=
# (tyhjä = suhteellinen URL, reverse proxy ohjaa /inboxpilot/api/ backendille)
#
# NEXT_PUBLIC_BASE_PATH=/inboxpilot
# (Next.js lisää tämän kaikkiin linkkeihin ja asset-polkuihin automaattisesti)
