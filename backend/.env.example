# ── Vaaditut ──────────────────────────────────────────────────────────────────

# OPENAI_API_KEY=your-key-here

# ── Valinnaiset ───────────────────────────────────────────────────────────────

# Malli — älä muuta tätä
OPENAI_MODEL=gpt-5-nano

# CORS: sallitut originit pilkulla erotettuina
# Kehitys:
ALLOWED_ORIGINS=http://localhost:3000
# Tuotanto:
# ALLOWED_ORIGINS=https://www.wisemancodes.com

# Viestin maksimipituus merkkeinä (oletusarvo 10000)
MAX_MESSAGE_LENGTH=10000
